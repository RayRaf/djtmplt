# ═══════════════════════════════════════════════════════════════
#  .env.example — Copy to .env for local development
#
#  In production (Dokploy): set these via Environment Settings UI,
#  NOT via .env file.
# ═══════════════════════════════════════════════════════════════

# ── Django ────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-50-char-string
# DEBUG is controlled by the settings module (dev.py=True, prod.py=False).
# This var is only used when running manage.py directly outside Docker.
DEBUG=1
DJANGO_SETTINGS_MODULE=config.settings.dev
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Database ──────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app_db
# DATABASE_URL is assembled from POSTGRES_* vars in docker-compose.yml.
# Only needed here if running manage.py directly outside Docker.
DATABASE_URL=postgres://postgres:postgres@db:5432/app_db

# ── Redis ─────────────────────────────────────────────────────
# In Docker Compose these are hardcoded to the internal service names.
# Only needed here if running outside Docker.
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=DEBUG
DJANGO_LOG_LEVEL=DEBUG

# ── Superuser (auto-created on first start if none exists) ────
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=changeme123

# ── Gunicorn / Celery tuning (optional) ───────────────────────
GUNICORN_WORKERS=3
CELERY_CONCURRENCY=2

# ── Sentry (optional, leave empty to disable) ─────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── S3 database backups (optional until backup commands are used) ──
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=
AWS_S3_REGION_NAME=
AWS_S3_ADDRESSING_STYLE=auto
AWS_S3_VERIFY=1
# Required for backups: objects are stored under
# <DB_BACKUP_S3_PREFIX>/database-backups/ in the bucket.
DB_BACKUP_S3_PREFIX=djtmplt

# ── Timezone ──────────────────────────────────────────────────
TZ=UTC
